generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RegistrationPhase {
  EarlyBird
  Regular
  LateOnsite
}

enum RegistrationType {
  student
  eastAfrica
  other
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DocumentType {
  INVOICE
  RECEIPT
}

enum DocumentStatus {
  ISSUED
  PAID
  VOID
}

model event_tbl {
  event_id   BigInt   @id @default(autoincrement())
  name       String
  code       String   @unique
  start_date DateTime?
  end_date   DateTime?

  isActive   Boolean  @default(true)

  registration participant_registration_tbl[]

  createdAt DateTime @default(now())
}

model participant_registration_tbl {
  participant_id          BigInt   @id @default(autoincrement())

  event_id               BigInt?
  event                  event_tbl? @relation(fields: [event_id], references: [event_id])

  full_name               String
  email                   String
  phone                   String
  organization            String
  country                 String
  profession              String
  other_profession        String?
  visa_info               String? 
  phase                   RegistrationPhase
  type                    RegistrationType
  other_accessibility     String? 
  required_translation    String? 
  other_dietary_restrictions String?
  media_consent           String
  report_consent          String
  emergency_contact       String?
  paid                    Boolean  @default(false)

  accessibility       registration_accessibility_tbl[]
  dietary             registration_dietary_tbl[]
  payments                payment_tbl[]
  documents               registration_document_tbl[]

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([email, event_id])
  @@index([email])
  @@index([event_id])
  @@index([phase])
  @@index([type])
}

model registration_accessibility_tbl {
  accessibility_id              BigInt   @id @default(autoincrement())
  participant_id                BigInt
  value                         String

  registration    participant_registration_tbl @relation(fields: [participant_id], references: [participant_id], onDelete: Cascade)

  @@index([participant_id])
}

model registration_dietary_tbl {
  dietary_id              BigInt   @id @default(autoincrement())
  participant_id          BigInt
  value                   String

  registration    participant_registration_tbl @relation(fields: [participant_id], references: [participant_id], onDelete: Cascade)

  @@index([participant_id])
}

model payment_tbl {
  payment_id              BigInt   @id @default(autoincrement())
  participant_id          BigInt
  amount                  Float
  currency                String   @default("USD")
  method                  String
  status                  PaymentStatus
  payment_reference       String?

  registration           participant_registration_tbl @relation(fields: [participant_id], references: [participant_id])
  documents              registration_document_tbl[]

  paidAt                  DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([participant_id])
  @@index([status])
  @@index([payment_reference])
}

model registration_document_tbl {
  document_id     BigInt         @id @default(autoincrement())
  participant_id  BigInt
  payment_id      BigInt?
  event_id        BigInt?
  type            DocumentType
  document_number String         @unique
  file_name       String
  file_path       String
  amount          Float
  currency        String         @default("USD")
  status          DocumentStatus @default(ISSUED)
  issued_at       DateTime       @default(now())

  participant participant_registration_tbl @relation(fields: [participant_id], references: [participant_id], onDelete: Cascade)
  payment     payment_tbl?                 @relation(fields: [payment_id], references: [payment_id], onDelete: SetNull)

  @@index([participant_id])
  @@index([payment_id])
  @@index([type])
  @@index([status])
  @@index([issued_at])
}

model NewsletterSubscriber {
  email_id           BigInt   @id @default(autoincrement())
  email              String   @unique
  isSubscribed       Boolean  @default(true)
  unsubscribeToken   String @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email])
}